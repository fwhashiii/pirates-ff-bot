# ─────────────────────────────────────────────
#  Free Fire Discord Bot — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Discord Bot Token (from discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# OpenAI API Key (for AI assistant feature — optional)
OPENAI_API_KEY=your_openai_api_key_here

# Channel IDs (right-click channel → Copy ID, needs Developer Mode on)
NEWS_CHANNEL_ID=123456789012345678
WELCOME_CHANNEL_ID=123456789012345678
LOG_CHANNEL_ID=123456789012345678

# Bot prefix for legacy commands (slash commands work without this)
PREFIX=!

# YouTube Data API v3 Key (console.cloud.google.com)
YOUTUBE_API_KEY=your_youtube_api_key_here
